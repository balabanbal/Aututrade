<!DOCTYPE html>

<html lang="tr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Varlık Yönetim Çizelgesi</title>
<style>
:root{
  --bg:#f0f3f9;--card:#fff;--border:#e4e8f0;--b2:#cbd2e0;
  --tx:#0f172a;--tx2:#475569;--tx3:#94a3b8;
  --ac:#2563eb;--acl:#eff4ff;--acd:#1d4ed8;
  --gr:#16a34a;--go:#92400e;--gol:#fef3c7;--re:#dc2626;
  --r:14px;--bar:68px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);font-family:-apple-system,'Helvetica Neue',Arial,sans-serif;
  color:var(--tx);padding:calc(var(--bar)+1.2rem) .9rem 3rem;-webkit-font-smoothing:antialiased}
.wrap{max-width:860px;margin:0 auto}

.bar{position:fixed;top:0;left:0;right:0;z-index:999;
background:rgba(255,255,255,.96);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
border-bottom:1px solid var(–border);padding:.7rem .9rem;
display:flex;align-items:center;justify-content:space-between;gap:.6rem;min-height:var(–bar)}
.bar-l .t{font-size:.93rem;font-weight:700;letter-spacing:-.02em}
.bar-l .s{font-size:.65rem;color:var(–tx3);margin-top:.1rem}
.bar-r{display:flex;flex-direction:column;align-items:flex-end;gap:.15rem}
.btn-ref{display:inline-flex;align-items:center;gap:.4rem;background:var(–ac);color:#fff;
border:none;border-radius:8px;padding:.55rem 1.1rem;font-size:.82rem;font-weight:600;
cursor:pointer;font-family:inherit;white-space:nowrap;transition:background .15s}
.btn-ref:hover:not(:disabled){background:var(–acd)}
.btn-ref:disabled{background:#93c5fd;cursor:not-allowed}
.upd{font-size:.63rem;color:var(–tx3)}
.err{font-size:.63rem;color:var(–re);font-weight:500}
@keyframes spin{to{transform:rotate(360deg)}}
.spinning{display:inline-block;animation:spin .7s linear infinite}

.banner{background:linear-gradient(135deg,#1e3a8a,#2563eb,#3b82f6);
border-radius:var(–r);padding:1rem 1.3rem;
display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;
margin-bottom:1.1rem;box-shadow:0 4px 20px rgba(37,99,235,.3)}
.banner .bl{font-size:.65rem;font-weight:600;color:rgba(255,255,255,.7);letter-spacing:.1em;text-transform:uppercase}
.banner .bv{font-size:clamp(1.4rem,5vw,2rem);font-weight:700;color:#fff;letter-spacing:-.02em;font-variant-numeric:tabular-nums}

.card{background:var(–card);border-radius:var(–r);border:1px solid var(–border);
box-shadow:0 1px 3px rgba(15,23,42,.04),0 6px 20px rgba(15,23,42,.06);margin-bottom:1.1rem;overflow:hidden}
.card-hd{padding:.75rem 1rem;border-bottom:1px solid var(–border);
display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.4rem}
.card-hd h2{font-size:.88rem;font-weight:600}
.badge{font-size:.61rem;font-weight:500;background:var(–acl);color:var(–ac);padding:.15rem .5rem;border-radius:20px}

.tw{overflow-x:auto;-webkit-overflow-scrolling:touch}
table{width:100%;border-collapse:collapse;min-width:380px}
thead th{padding:.5rem .75rem;font-size:.61rem;font-weight:600;color:var(–tx3);
text-transform:uppercase;letter-spacing:.07em;border-bottom:1px solid var(–border);
background:#fafbfe;white-space:nowrap}
th.c,td.c{text-align:center}
th.r,td.r{text-align:right}
tbody td{padding:.55rem .75rem;font-size:.82rem;border-bottom:1px solid #f1f4fb;vertical-align:middle}
tbody tr:last-child td{border-bottom:none}
tbody tr:hover{background:#f8faff}
tfoot td{padding:.6rem .75rem;font-size:.75rem;font-weight:600;color:var(–tx2);
background:#f8f9fe;border-top:2px solid var(–border)}
.sv{color:var(–ac);font-size:.88rem;text-align:right;font-variant-numeric:tabular-nums}

.tag{display:inline-block;background:var(–gol);color:var(–go);font-size:.59rem;font-weight:700;
padding:.1rem .32rem;border-radius:4px;margin-right:.3rem;letter-spacing:.04em}
.aname{font-weight:500}
.pval{color:var(–gr);font-weight:600;font-variant-numeric:tabular-nums;font-size:.82rem}
.pload{color:var(–tx3);font-size:.75rem}
.tval{font-weight:600;font-variant-numeric:tabular-nums}
.temp{color:var(–tx3)}

input[type=number],input[type=text]{
background:#f4f6fb;border:1px solid var(–b2);border-radius:7px;
color:var(–tx);padding:.4rem .5rem;font-size:.83rem;outline:none;width:100%;
-webkit-appearance:none;transition:border-color .15s,box-shadow .15s}
input:focus{border-color:var(–ac);box-shadow:0 0 0 3px rgba(37,99,235,.12);background:#fff}
.in-num{text-align:right;font-variant-numeric:tabular-nums}
.in-code{text-align:center;font-weight:700;color:var(–ac);letter-spacing:.06em;text-transform:uppercase}
.fn-wrap{position:relative}
.fn-wrap input{padding-right:1.6rem}
.fn-ico{position:absolute;right:.4rem;top:50%;transform:translateY(-50%);font-size:.8rem;pointer-events:none}
.ok{color:var(–gr)} .no{color:var(–re)}

.btn-del{background:#fff;border:1px solid var(–b2);color:var(–tx3);border-radius:6px;
width:28px;height:28px;cursor:pointer;font-size:.8rem;
display:inline-flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0}
.btn-del:hover:not(:disabled){background:#fef2f2;border-color:#fca5a5;color:var(–re)}
.btn-del:disabled{opacity:.3;cursor:not-allowed}
.btn-add{display:inline-flex;align-items:center;gap:.35rem;margin:.6rem .75rem .75rem;
background:var(–acl);color:var(–ac);border:1.5px dashed #93c5fd;border-radius:8px;
padding:.42rem .9rem;font-size:.76rem;font-weight:600;cursor:pointer;transition:all .15s}
.btn-add:hover{background:#dbeafe;border-color:var(–ac)}
.note{text-align:center;color:var(–tx3);font-size:.64rem;padding-top:.2rem}

@media(max-width:600px){
body{padding-left:.6rem;padding-right:.6rem}
thead th,tbody td{padding:.45rem .5rem;font-size:.75rem}
}
</style>

</head>
<body>
<div class="bar">
  <div class="bar-l">
    <div class="t">Varlık Yönetim Çizelgesi</div>
    <div class="s">Döviz · Altın · Yatırım Fonları</div>
  </div>
  <div class="bar-r">
    <button class="btn-ref" id="btnRef" onclick="fetchAll()">
      <span id="refIco">↻</span> Fiyatları Yenile
    </button>
    <div class="upd" id="lastUp"></div>
    <div class="err" id="errMsg"></div>
  </div>
</div>

<div class="wrap">
  <div class="banner">
    <span class="bl">Toplam Net Varlık</span>
    <span class="bv" id="grand">— ₺</span>
  </div>

  <div class="card">
    <div class="card-hd">
      <h2>💵 Döviz &amp; Altın</h2>
      <span class="badge">Anlık serbest piyasa fiyatları</span>
    </div>
    <div class="tw">
      <table>
        <thead><tr>
          <th>Varlık</th>
          <th class="c" style="width:110px">Miktar</th>
          <th class="c" style="width:130px">Satış Fiyatı (₺)</th>
          <th class="r" style="width:120px">Toplam (₺)</th>
        </tr></thead>
        <tbody>
          <tr>
            <td><span class="tag">USD</span><span class="aname">Amerikan Doları</span></td>
            <td class="c"><input type="number" class="in-num" id="amt-USD" placeholder="0" min="0" step="any" oninput="recalc()"/></td>
            <td class="c" id="prc-USD-cell"><span class="pload">yükleniyor…</span></td>
            <td class="r" id="tot-USD"><span class="temp">—</span></td>
          </tr>
          <tr>
            <td><span class="tag">EUR</span><span class="aname">Euro</span></td>
            <td class="c"><input type="number" class="in-num" id="amt-EUR" placeholder="0" min="0" step="any" oninput="recalc()"/></td>
            <td class="c" id="prc-EUR-cell"><span class="pload">yükleniyor…</span></td>
            <td class="r" id="tot-EUR"><span class="temp">—</span></td>
          </tr>
          <tr>
            <td><span class="tag">XAU</span><span class="aname">Gram Altın (Has)</span></td>
            <td class="c"><input type="number" class="in-num" id="amt-XAU" placeholder="0" min="0" step="any" oninput="recalc()"/></td>
            <td class="c" id="prc-XAU-cell"><span class="pload">yükleniyor…</span></td>
            <td class="r" id="tot-XAU"><span class="temp">—</span></td>
          </tr>
        </tbody>
        <tfoot><tr>
          <td colspan="3">Ara Toplam</td>
          <td class="sv" id="aSub">—</td>
        </tr></tfoot>
      </table>
    </div>
  </div>

  <div class="card">
    <div class="card-hd">
      <h2>📈 Yatırım Fonları</h2>
      <span class="badge">Kod gir → ad &amp; fiyat otomatik</span>
    </div>
    <div class="tw">
      <table>
        <thead><tr>
          <th style="width:76px">Kod</th>
          <th>Fon Adı</th>
          <th class="c" style="width:100px">Fiyat (₺)</th>
          <th class="c" style="width:90px">Pay</th>
          <th class="r" style="width:110px">Toplam (₺)</th>
          <th style="width:36px"></th>
        </tr></thead>
        <tbody id="fBody"></tbody>
        <tfoot><tr>
          <td colspan="5">Ara Toplam</td>
          <td class="sv" id="fSub">—</td>
          <td></td>
        </tr></tfoot>
      </table>
    </div>
    <button class="btn-add" onclick="addFund()">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Fon Ekle
    </button>
  </div>
  <p class="note">Fon adları TEFAS kaynaklıdır · Yatırım tavsiyesi değildir</p>
</div>

