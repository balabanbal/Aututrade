/* ── FİYATLAR ── */
const prices={USD:0,EUR:0,XAU:0};
const fmt=v=>v>0?v.toLocaleString('tr-TR',{minimumFractionDigits:2,maximumFractionDigits:2}):'—';
const fmt4=v=>v>0?v.toLocaleString('tr-TR',{minimumFractionDigits:4,maximumFractionDigits:4}):'—';

function showPrice(code,val){
  prices[code]=val;
  const cell=document.getElementById('prc-'+code+'-cell');
  if(cell) cell.innerHTML=`<span class="pval">${fmt(val)} ₺</span>`;
  recalc();
}

async function fetchAll(){
  const btn=document.getElementById('btnRef');
  const ico=document.getElementById('refIco');
  const up=document.getElementById('lastUp');
  const err=document.getElementById('errMsg');
  btn.disabled=true;
  ico.className='spinning';
  up.textContent='güncelleniyor…';
  err.textContent='';

  let ok=0;
  // 1) USD/TRY + EUR/TRY — frankfurter.dev (CORS açık, key yok)
  try{
    const r=await fetch('https://api.frankfurter.dev/v1/latest?base=TRY&symbols=USD,EUR');
    const d=await r.json();
    if(d.rates){
      showPrice('USD', parseFloat((1/d.rates.USD).toFixed(4)));
      showPrice('EUR', parseFloat((1/d.rates.EUR).toFixed(4)));
      ok++;
    }
  }catch(e){ err.textContent='Döviz alınamadı'; }

  // 2) Gram Altın — truncgil (serbest piyasa has altın)
  const goldUrl='https://finans.truncgil.com/v4/today.json';
  const proxies=[
    goldUrl,
    'https://api.allorigins.win/raw?url='+encodeURIComponent(goldUrl),
    'https://api.allorigins.win/get?url='+encodeURIComponent(goldUrl),
    'https://corsproxy.io/?url='+encodeURIComponent(goldUrl),
  ];
  for(const url of proxies){
    try{
      const r=await fetch(url,{cache:'no-store'});
      if(!r.ok) continue;
      let d=await r.json();
      if(d.contents) d=JSON.parse(d.contents);
      const g=d?.HAS?.Selling||d?.GRA?.Selling||d?.['HAS']?.Selling;
      if(g){ showPrice('XAU',parseFloat(parseFloat(g).toFixed(2))); ok++; break; }
    }catch(e){}
  }

  up.textContent=ok>0?'Son güncelleme: '+new Date().toLocaleTimeString('tr-TR'):'';
  if(ok===0) err.textContent='Fiyatlar alınamadı';
  btn.disabled=false;
  ico.className='';
}

/* ── HESAP ── */
function recalc(){
  let aSum=0;
  ['USD','EUR','XAU'].forEach(c=>{
    const amt=parseFloat(document.getElementById('amt-'+c)?.value)||0;
    const prc=prices[c]||0;
    const t=amt&&prc?amt*prc:0;
    document.getElementById('tot-'+c).innerHTML=
      t>0?`<span class="tval">${fmt(t)} ₺</span>`:'<span class="temp">—</span>';
    aSum+=t;
  });
  document.getElementById('aSub').textContent=aSum>0?fmt(aSum)+' ₺':'—';

  let fSum=0;
  fundRows.forEach(id=>{
    const p=parseFloat(document.getElementById('fp'+id)?.value)||0;
    const a=parseFloat(document.getElementById('fa'+id)?.value)||0;
    const t=p&&a?p*a:0;
    const el=document.getElementById('ft'+id);
    if(el) el.innerHTML=t>0?`<span class="tval">${fmt(t)} ₺</span>`:'<span class="temp">—</span>';
    fSum+=t;
  });
  document.getElementById('fSub').textContent=fSum>0?fmt(fSum)+' ₺':'—';
  document.getElementById('grand').textContent=(aSum+fSum)>0?fmt(aSum+fSum)+' ₺':'— ₺';
}

/* ── TEFAS FON FİYATI ── */
async function fetchFundPrice(id){
  const code=document.getElementById('fc'+id)?.value.trim().toUpperCase();
  const fp=document.getElementById('fp'+id);
  if(!code||code.length<2||!fp) return;
  fp.placeholder='…';
  const today=new Date();
  // hafta sonu ise son Cuma
  const d=new Date(today);
  if(d.getDay()===0) d.setDate(d.getDate()-2);
  if(d.getDay()===6) d.setDate(d.getDate()-1);
  const dt=d.getDate().toString().padStart(2,'0')+'.'+(d.getMonth()+1).toString().padStart(2,'0')+'.'+d.getFullYear();
  const body=`fontip=YAT&sfonkod=${code}&bastarih=${dt}&bittarih=${dt}&fonkod=${code}`;
  const tefas='https://www.tefas.gov.tr/api/DB/BindHistoryInfo';
  const tryUrls=[
    'https://corsproxy.io/?url='+encodeURIComponent(tefas),
    'https://api.allorigins.win/raw?url='+encodeURIComponent(tefas),
  ];
  for(const url of tryUrls){
    try{
      const r=await fetch(url,{method:'POST',
        headers:{'Content-Type':'application/x-www-form-urlencoded'},body});
      if(!r.ok) continue;
      const d2=await r.json();
      const rows=d2?.data||d2?.Data||[];
      if(rows.length>0){
        const p=rows[0].FIYAT||rows[0].Fiyat||rows[0].fiyat;
        if(p){
          fp.value=parseFloat(p).toFixed(4);
          fp.style.color='#16a34a';
          fp.style.fontWeight='600';
          recalc(); return;
        }
      }
    }catch(e){}
  }
  fp.placeholder='Fiyat girin';
}

/* ── FON SATIRLARI ── */
const fundRows=[];
let ctr=1;
const debounce={};

function onCodeInput(id){
  const el=document.getElementById('fc'+id);
  el.value=el.value.replace(/[^a-zA-ZğüşıöçĞÜŞİÖÇ0-9]/g,'').toUpperCase().slice(0,6);
  clearTimeout(debounce[id]);
  debounce[id]=setTimeout(()=>{
    lookupName(id);
    if(el.value.length>=3) fetchFundPrice(id);
  },500);
}

function lookupName(id){
  const code=document.getElementById('fc'+id)?.value.toUpperCase();
  const ni=document.getElementById('fn'+id);
  const ico=document.getElementById('fni'+id);
  if(!ni||!ico) return;
  if(F[code]){ ni.value=F[code]; ico.className='fn-ico ok'; ico.textContent='✓'; }
  else { ico.className='fn-ico no'; ico.textContent=code.length>=2?'?':''; }
}

function addFund(){
  const id=ctr++; fundRows.push(id);
  const tr=document.createElement('tr'); tr.id='fr'+id;
  tr.innerHTML=`
    <td><input type="text" class="in-code" id="fc${id}" placeholder="KOD"
      maxlength="6" autocomplete="off" autocorrect="off" autocapitalize="characters" spellcheck="false"
      oninput="onCodeInput(${id})"
      style="width:68px;font-size:.9rem;padding:.42rem .3rem;text-align:center"/></td>
    <td><div class="fn-wrap">
      <input type="text" id="fn${id}" placeholder="kod gir → ad otomatik gelir"
        autocomplete="off" spellcheck="false" style="width:100%;font-size:.8rem"/>
      <span class="fn-ico" id="fni${id}"></span>
    </div></td>
    <td class="c"><input type="number" class="in-num" id="fp${id}"
      placeholder="—" step="0.0001" min="0" oninput="recalc()"
      style="width:90px;font-size:.82rem"/></td>
    <td class="c"><input type="number" class="in-num" id="fa${id}"
      placeholder="0" step="any" min="0" oninput="recalc()"
      style="width:80px;font-size:.82rem"/></td>
    <td class="r" id="ft${id}"><span class="temp">—</span></td>
    <td class="c"><button class="btn-del" onclick="delFund(${id})" title="Sil">✕</button></td>`;
  document.getElementById('fBody').appendChild(tr);
  updDel();
}

function delFund(id){
  document.getElementById('fr'+id)?.remove();
  const i=fundRows.indexOf(id);
  if(i>-1) fundRows.splice(i,1);
  updDel(); recalc();
}

function updDel(){
  document.querySelectorAll('.btn-del').forEach(b=>b.disabled=fundRows.length<=1);
}

addFund();
fetchAll();
</script>

